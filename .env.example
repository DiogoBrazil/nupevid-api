DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
# If the password contains @, :, / or similar, URL-encode it in the URLs below.
DATABASE_URL=postgresql://user:password@localhost:5432/database
DOCKER_DATABASE_URL=postgresql://user:password@postgres:5432/database
DATABASE_TEST_URL=postgresql://user:password@localhost:5432/database_test
SERVER_ADDR=0.0.0.0:8080
JWT_SECRET=your_jwt_secret_key_here
JWT_ISSUER=nupevid-api
JWT_AUDIENCE=nupevid-api
# Access token (JWT) lifetime in seconds. Default: 900 (15 minutes).
ACCESS_TOKEN_TTL_SECONDS=900
# Refresh token lifetime in seconds. Default: 604800 (7 days).
REFRESH_TOKEN_TTL_SECONDS=604800
API_KEY=your_api_key_here
DB_MAX_CONNECTIONS=20
ENABLE_BOOTSTRAP_ROOT=false
# Apply pending DB migrations automatically on startup. Default: true.
RUN_MIGRATIONS_ON_STARTUP=true
RUST_LOG=info

# LogStreamer (log viewer UI)
LOGSTREAMER_ADMIN=admin
LOGSTREAMER_PASSWORD=change-this-in-production
LOGSTREAMER_JWT_SECRET=generate_a_64_hex_secret_for_production
LOGSTREAMER_BASE_PATH=/logstreamer

# Traefik
TRAEFIK_LOG_LEVEL=INFO
